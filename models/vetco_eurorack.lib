* ================================================================
* SECTION 2: JUNCTION FIELD-EFFECT TRANSISTORS (JFET)
*
* All models use standard ngspice NJF/PJF .model syntax.
* Physical pin order (TO-92): 1=Drain  2=Gate  3=Source
* ================================================================

* ----------------------------------------------------------------
* NTE457 — N-Channel JFET General Purpose  (2N5457 equivalent)
*   VGS(off)=-6V max  IDSS=1–5mA  VDS=25V  fT=100MHz
*   Use: CV control; VCRs in filters; simple VCAs.
*   Source: Central Semiconductor 2N5457 SPICE model.
* ----------------------------------------------------------------
.MODEL NTE457 NJF(
+ VTO=-1.4676  BETA=1.6275m  LAMBDA=0.883m
+ RD=1         RS=1
+ CGS=4.5p     CGD=1.5p
+ PB=1         FC=0.5       IS=35.7p
+ KF=9.9E-18   AF=1 )

* ----------------------------------------------------------------
* NTE458 — N-Channel JFET Low-Noise Audio  (J201 / 2N4117 equiv.)
*   VGS(off)=-0.3 to -1.5V  IDSS=0.2–1mA  VDS=50V
*   Use: Low-noise audio input stages; primary audio path.
*   Source: InterFET J201 SPICE model parameters.
* ----------------------------------------------------------------
.MODEL NTE458 NJF(
+ VTO=-0.80    BETA=1.0m    LAMBDA=10m
+ RD=50        RS=50
+ CGS=25p      CGD=5p
+ PB=0.5       FC=0.5       IS=1E-14
+ KF=1E-18     AF=1 )

* ----------------------------------------------------------------
* NTE467 — N-Channel JFET Switching  (2N5458 equivalent)
*   VGS(off)=-7V max  IDSS=2–9mA  VDS=30V
*   Use: S&H circuits; analog switches (low Rds(on)).
*   Source: Published 2N5458 SPICE model.
* ----------------------------------------------------------------
.MODEL NTE467 NJF(
+ VTO=-2.882   BETA=0.489m  LAMBDA=3.167m
+ RD=1         RS=1
+ CGS=4.627p   CGD=4p
+ PB=1         FC=0.5       IS=181.3E-15
+ KF=9.9E-18   AF=1 )

* ----------------------------------------------------------------
* NTE489 — P-Channel JFET  (2N5462 equivalent)
*   VGS(off)=+3 to +7.5V  IDSS=4–16mA  VDS=30V  Ic=50mA
*   Use: Complementary P-channel; push-pull output stages.
*   Source: Vishay Siliconix 2N5462 SPICE parameters.
* ----------------------------------------------------------------
.MODEL NTE489 PJF(
+ VTO=3.50     BETA=0.65m   LAMBDA=5m
+ RD=1         RS=1
+ CGS=5p       CGD=2p
+ PB=1         FC=0.5       IS=35.7p )

* ----------------------------------------------------------------
* VET469 — N-Channel JFET High-Current  (NTE469)
*   VGS(off)=-0.5 to -4V  IDSS(max)=30mA (NTE469)  VDS=35V
*   Use: Driving heavier loads; "chopper" circuits.
*   Source: NTE469 datasheet (equivalent: PN4393, BSJ113, J113);
*           BETA scaled for IDSS=30mA at VGS=0 (BETA = IDSS / VTO^2 = 30m/4 = 7.5m).
* ----------------------------------------------------------------
.MODEL VET469 NJF(
+ VTO=-2.00    BETA=7.5m    LAMBDA=8m
+ RD=20        RS=20
+ CGS=4p       CGD=2p
+ PB=1         FC=0.5       IS=1E-14 )

* ----------------------------------------------------------------
* NTE460 — P-Channel JFET  (2N5460-type, 20V variant)
*   VGS(off)=+0.75 to +6V  IDSS=1–5mA  VDS=20V
*   Use: Low-voltage sub-sections (0–10V); caution on ±12V rails.
*   Source: 2N5460 parameters de-rated to 20V operation.
* ----------------------------------------------------------------
.MODEL NTE460 PJF(
+ VTO=2.50     BETA=0.5m    LAMBDA=5m
+ RD=1         RS=1
+ CGS=4p       CGD=1.5p
+ PB=0.75      FC=0.5       IS=35.7p )

* ----------------------------------------------------------------
* NTE326 — P-Channel JFET High-Voltage  (2N5460-type, 40V)
*   VGS(off)=+0.75 to +9V  IDSS=1–5mA  VDS=40V
*   Use: Full Eurorack rail swing; safe for 24V differential.
*   Source: 2N5460 parameters calibrated for full 40V operation.
* ----------------------------------------------------------------
.MODEL NTE326 PJF(
+ VTO=3.50     BETA=0.25m   LAMBDA=4m
+ RD=1         RS=1
+ CGS=4p       CGD=1.5p
+ PB=1         FC=0.5       IS=35.7p )


* ================================================================
* SECTION 3: OPERATIONAL AMPLIFIERS
*
* Single-section parts (LM741N, NTE976) have 5-pin subcircuits:
*   Pin 1 = Non-Inverting Input  (IN+)
*   Pin 2 = Inverting Input      (IN-)
*   Pin 3 = Positive Supply      (V+)
*   Pin 4 = Negative Supply      (V-)
*   Pin 5 = Output               (OUT)
*
* Multi-section parts (dual/quad) expose a package-level wrapper
* with named pins (VCC VEE INA_P INA_N OUTA ...) that internally
* instantiate <Name>_SEC cores sharing the supply rails.
*
* Boyle-type macro models (IEEE J. Solid-State Circuits, 1974).
* GBW is set by GA / (2*pi*C2); slew rate by IEE / C2.
* VLP/VLN set the maximum output excursion from the rails.
*
* ================================================================

* ----------------------------------------------------------------
* LM741N — Single Op-Amp  (Texas Instruments / National Semi.)
*   Avol≈106dB  GBW=1MHz  SR=0.5V/µs  Rails=±18V  Iout=25mA
*   Use: Vintage/lo-fi oscillators; distortion circuits.
*   Source: Classic Boyle macro model; TI data sheet parameters.
* ----------------------------------------------------------------
.SUBCKT LM741N 1 2 3 4 5
*               IN+ IN- V+ V- OUT
*
C1   11 12 8.661E-12
C2    6  7 30.00E-12
DC    5 53 DX
DE   54  5 DX
DLP  90 91 DX
DLN  92 90 DX
DP    4  3 DX
EGND 99  0 VALUE = {0.5*V(3) + 0.5*V(4)}
FB1   7 99 VB  21.22E6
FB2   7 99 VC -20E6
FB3   7 99 VE  20E6
FB4   7 99 VLP 20E6
FB5   7 99 VLN -20E6
GA    6  0 11 12 188.5E-6
GCM   0  6 10 99 5.961E-9
IEE  10  4 DC 15.16E-6
HLIM 90  0 VLIM 1K
Q1   11  2 13 QX
Q2   12  1 14 QX
R2    6  9 100.0E3
RC1   3 11 5.305E3
RC2   3 12 5.305E3
RE1  13 10 1.836E3
RE2  14 10 1.836E3
REE  10 99 13.19E6
RO1   8  5 50
RO2   7 99 25
RP    3  4 18.16E3
VB    9  0 DC 0
VC    3 53 DC 1
VE   54  4 DC 1
VLIM  7  8 DC 0
VLP  91  0 DC 40
VLN   0 92 DC 40
.MODEL DX D(IS=800.0E-18 RS=1)
.MODEL QX NPN(IS=800.0E-18 BF=93.75)
.ENDS LM741N

