FB3   7 99 VE  40E6
FB4   7 99 VLP 40E6
FB5   7 99 VLN -40E6
GA    6  0 11 12 565.8E-6
GCM   0  6 10 99 5.961E-9
IEE  10  4 DC 40.0E-6
HLIM 90  0 VLIM 1K
Q1   11  2 13 QX
Q2   12  1 14 QX
R2    6  9 100.0E3
RC1   3 11 2.000E3
RC2   3 12 2.000E3
RE1  13 10 680
RE2  14 10 680
REE  10 99 12.5E6
RO1   8  5 40
RO2   7 99 0.3
RP    3  4 7.843E3
VB    9  0 DC 0
VC    3 53 DC 2
VE   54  4 DC 2
VLIM  7  8 DC 0
VLP  91  0 DC 40
VLN   0 92 DC 40
.MODEL DX D(IS=800.0E-18 RS=1)
.MODEL QX NPN(IS=800.0E-18 BF=250)
.ENDS NTE824_SEC

